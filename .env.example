# --- Traceloop Configuration ---
# Ottieni la tua chiave su https://app.traceloop.com
TRACELOOP_API_KEY=tlp_your_api_key_here

# --- LLM Configuration ---
# Il modello da utilizzare (es. llama3.2:1b, gemma2:2b, phi3)
# Default: llama3.2:1b
LLM_MODEL=llama3.2:1b

# --- Connection Configuration ---
# L'endpoint del server Ollama. 
# Usa http://ollama:11434 per l'esecuzione dentro Docker
# Usa http://localhost:11434 per l'esecuzione locale (fuori Docker)
OLLAMA_HOST=http://ollama:11434
